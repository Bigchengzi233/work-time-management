<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace 必须和 Java 中的 ProjectMapper 接口全限定名一致。 -->
<mapper namespace="com.worktime.mapper.ProjectMapper">

    <!-- 项目与部门连接查询结果映射。 -->
    <resultMap id="ProjectRowResultMap" type="com.worktime.vo.ProjectRowVO">
        <id column="project_id" property="projectId"/>
        <result column="project_name" property="projectName"/>
        <result column="project_status" property="projectStatus"/>
        <result column="dept_id" property="deptId"/>
        <result column="dept_name" property="deptName"/>
    </resultMap>

    <!-- 项目列表基础查询 SQL。 -->
    <sql id="ProjectSelectColumns">
        SELECT
            p.project_id,
            p.project_name,
            p.project_status,
            p.dept_id,
            d.dept_name
        FROM project p
        LEFT JOIN department d ON p.dept_id = d.dept_id
    </sql>

    <!-- 查询全部项目。 -->
    <select id="selectAll" resultMap="ProjectRowResultMap">
        <include refid="ProjectSelectColumns"/>
        ORDER BY p.project_id ASC
    </select>

    <!-- 根据项目编号查询单个项目。 -->
    <select id="selectById" resultMap="ProjectRowResultMap">
        <include refid="ProjectSelectColumns"/>
        WHERE p.project_id = #{projectId}
    </select>

    <!-- 检查所属部门是否存在。 -->
    <select id="countDepartmentById" resultType="int">
        SELECT COUNT(1)
        FROM department
        WHERE dept_id = #{deptId}
    </select>

    <!-- 新增项目。 -->
    <insert id="insert" parameterType="com.worktime.entity.Project" useGeneratedKeys="true" keyProperty="projectId">
        INSERT INTO project (
            project_name,
            project_status,
            dept_id
        ) VALUES (
            #{projectName},
            #{projectStatus},
            #{deptId}
        )
    </insert>

    <!-- 根据项目编号修改项目。 -->
    <update id="updateById" parameterType="com.worktime.entity.Project">
        UPDATE project
        SET
            project_name = #{projectName},
            project_status = #{projectStatus},
            dept_id = #{deptId}
        WHERE project_id = #{projectId}
    </update>

    <!-- 统计项目是否存在员工授权记录。 -->
    <select id="countUserProjectsByProjectId" resultType="int">
        SELECT COUNT(1)
        FROM user_project
        WHERE project_id = #{projectId}
    </select>

    <!-- 统计项目是否存在工时申报单。 -->
    <select id="countWorkTimesByProjectId" resultType="int">
        SELECT COUNT(1)
        FROM work_time_apply
        WHERE project_id = #{projectId}
    </select>

    <!-- 根据项目编号删除项目。 -->
    <delete id="deleteById">
        DELETE FROM project
        WHERE project_id = #{projectId}
    </delete>
</mapper>
