<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace 必须和 Java 中的 DepartmentMapper 接口全限定名一致。 -->
<mapper namespace="com.worktime.mapper.DepartmentMapper">

    <!-- resultMap 用于说明 SQL 查询结果如何映射到 Department 实体类。 -->
    <resultMap id="DepartmentResultMap" type="com.worktime.entity.Department">
        <!-- dept_id 是数据库字段，deptId 是 Java 属性。 -->
        <id column="dept_id" property="deptId"/>
        <!-- dept_name 是数据库字段，deptName 是 Java 属性。 -->
        <result column="dept_name" property="deptName"/>
    </resultMap>

    <!-- id 必须和 DepartmentMapper 接口中的方法名 selectAll 一致。 -->
    <select id="selectAll" resultMap="DepartmentResultMap">
        SELECT
            dept_id,
            dept_name
        FROM department
        ORDER BY dept_id ASC
    </select>

    <!-- 根据部门编号查询单个部门，#{deptId} 会接收 Java 方法传入的参数。 -->
    <select id="selectById" resultMap="DepartmentResultMap">
        SELECT
            dept_id,
            dept_name
        FROM department
        WHERE dept_id = #{deptId}
    </select>

    <!-- 根据部门名称统计数量，用于新增时检查部门名称是否重复。 -->
    <select id="countByDeptName" resultType="int">
        SELECT COUNT(1)
        FROM department
        WHERE dept_name = #{deptName}
    </select>

    <!-- 修改部门时检查名称是否被其他部门占用。 -->
    <select id="countByDeptNameExcludeId" resultType="int">
        SELECT COUNT(1)
        FROM department
        WHERE dept_name = #{deptName}
          AND dept_id != #{deptId}
    </select>

    <!-- 新增部门，useGeneratedKeys 会把数据库自增主键回填到 Department.deptId。 -->
    <insert id="insert" parameterType="com.worktime.entity.Department" useGeneratedKeys="true" keyProperty="deptId">
        INSERT INTO department (
            dept_name
        ) VALUES (
            #{deptName}
        )
    </insert>

    <!-- 根据部门编号修改部门名称。 -->
    <update id="updateById" parameterType="com.worktime.entity.Department">
        UPDATE department
        SET dept_name = #{deptName}
        WHERE dept_id = #{deptId}
    </update>

    <!-- 统计某部门下是否还有用户。 -->
    <select id="countUsersByDeptId" resultType="int">
        SELECT COUNT(1)
        FROM `user`
        WHERE dept_id = #{deptId}
    </select>

    <!-- 统计某部门下是否还有项目。 -->
    <select id="countProjectsByDeptId" resultType="int">
        SELECT COUNT(1)
        FROM project
        WHERE dept_id = #{deptId}
    </select>

    <!-- 根据部门编号删除部门。 -->
    <delete id="deleteById">
        DELETE FROM department
        WHERE dept_id = #{deptId}
    </delete>
</mapper>
